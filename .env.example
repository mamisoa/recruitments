# Copy to .env and fill in. The .env file is git-ignored and never baked into the image.

# AI — any OpenAI-compatible /v1 endpoint (OpenRouter, OpenAI, vLLM, …).
# Base URL of the endpoint (must include the /v1 suffix).
#   OpenRouter:        https://openrouter.ai/api/v1
#   Local vLLM (gemma): https://g412b.c66.ovh/v1
AI_BASE_URL=https://openrouter.ai/api/v1

# Bearer token for the endpoint (OpenRouter key, or the vLLM deployment's VLLM_API_KEY).
# Required for all AI features (generation, extraction, summaries).
AI_API_KEY=

# Model name as exposed by the endpoint. Must be multimodal to read PDFs.
#   OpenRouter: openai/gpt-5.4-mini   |   vLLM: gemma-4-12b-it
AI_MODEL=openai/gpt-5.4-mini

# Persistence. In Docker these are overridden by docker-compose to point at the volume.
DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=15

# CORS origins for local dev (Vite). Leave as-is for dev; set to [] in production.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
